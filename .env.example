# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local PGlite/Postgres database path for Drizzle.
DATABASE_URL="./local.db"

# Clerk scaffold is installed but MIS still uses LoginPortal in v1.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Optional SaaS observability/security providers.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORGANIZATION=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
ARCJET_KEY=""

# SMTP: Required for real email delivery from CRM/admissions and task reminders.
# Without these values, the server falls back to Ethereal/console test mode.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"
EMAIL_FROM="MIS Smart Portal <noreply@mis.edu.vn>"
# Optional: route all reminder emails to one test mailbox during QA.
TEST_RECEIVER_EMAIL=""
MAX_EMAIL_REMINDERS_PER_RUN="5"
MAX_CAMPAIGN_EMAILS_PER_RUN="20"

# Zalo OA Broadcast: optional, used by System Settings to prepare OA broadcast drafts.
# Keep token values in Render Environment only; do not commit real secrets.
ZALO_OA_ID=""
ZALO_APP_ID=""
ZALO_APP_SECRET=""
ZALO_ACCESS_TOKEN=""
ZALO_REFRESH_TOKEN=""
ZALO_DEFAULT_AUDIENCE="Người quan tâm OA"

# VietQR Admissions Payment: used to generate reservation/enrollment QR codes.
# Use bank BIN from VietQR/NAPAS, receiving account number, and account holder name.
BANK_BIN="970436"
BANK_ACCOUNT_NO="0123456789"
BANK_ACCOUNT_NAME="MIS SMART SCHOOL"
PAYMENT_PREFIX_RESERVATION="GCHO"
PAYMENT_PREFIX_ENROLLMENT="NHAPHOC"
